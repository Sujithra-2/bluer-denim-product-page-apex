<div style="max-width: 900px; margin: 50px auto; font-family: 'Helvetica Neue', sans-serif; padding: 20px;">
  <h1 style="text-align: center; text-transform: uppercase; margin-bottom: 40px;">Your Shopping Cart</h1>

  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" novalidate>
      <table style="width: 100%; border-collapse: collapse; margin-bottom: 30px;">
        <thead>
          <tr style="border-bottom: 2px solid #000; text-align: left;">
            <th style="padding: 15px 0;">Product</th>
            <th style="padding: 15px 0; text-align: center;">Price</th>
            <th style="padding: 15px 0; text-align: center;">Quantity</th>
            <th style="padding: 15px 0; text-align: right;">Total</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr style="border-bottom: 1px solid #eee;">
              <td style="padding: 15px 0; display: flex; align-items: center; gap: 15px;">
                
                {% if item.image %}
                  <img src="{{ item.image | img_url: '100x' }}" alt="{{ item.title | escape }}" style="width: 80px; height: auto; border-radius: 5px; object-fit: cover;">
                {% endif %}
                
                <div>
                  <strong style="font-size: 16px;">{{ item.product.title }}</strong><br>
                  <span style="color: #666; font-size: 14px;">Size: {{ item.variant.title }}</span>
                </div>
              </td>
              <td style="padding: 15px 0; text-align: center;">{{ item.price | money }}</td>
              <td style="padding: 15px 0; text-align: center;">{{ item.quantity }}</td>
              <td style="padding: 15px 0; text-align: right; font-weight: bold;">{{ item.line_price | money }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div style="text-align: right; padding-top: 20px;">
        <h2 style="margin-bottom: 20px;">Subtotal: {{ cart.total_price | money }}</h2>
        <button type="submit" name="checkout" style="padding: 15px 30px; background-color: #000; color: #fff; font-size: 16px; border: none; cursor: pointer; text-transform: uppercase;">
          Proceed to Checkout
        </button>
      </div>
    </form>
  {% else %}
    <div style="text-align: center;">
      <p style="font-size: 18px; color: #666;">Your cart is currently empty.</p>
      <a href="/" style="display: inline-block; margin-top: 20px; padding: 15px 30px; background-color: #000; color: #fff; text-decoration: none; text-transform: uppercase;">Continue Shopping</a>
    </div>
  {% endif %}
</div>