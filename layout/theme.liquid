<!DOCTYPE html>
<html>
<head>
  {{ content_for_header }}
  <style>
    /* Adding a quick reset so the black footer touches the edges perfectly */
    body { margin: 0; padding: 0; }
  </style>
</head>
<body>
  {{ content_for_layout }}

  <footer style="background-color: #000; color: #fff; padding: 60px 20px; font-family: 'Helvetica Neue', sans-serif; margin-top: 60px;">
    <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; gap: 30px;">
      
      <div style="flex: 1; min-width: 150px;">
        <h4 style="margin-bottom: 20px; font-size: 16px;">Account</h4>
        <ul style="list-style: none; padding: 0; margin: 0; line-height: 2.2; font-size: 14px;">
          <li><a href="#" style="color: #999; text-decoration: none;">Log In</a></li>
          <li><a href="#" style="color: #999; text-decoration: none;">Create an Account</a></li>
          <li><a href="#" style="color: #999; text-decoration: none;">My Orders</a></li>
        </ul>
      </div>

      <div style="flex: 1; min-width: 150px;">
        <h4 style="margin-bottom: 20px; font-size: 16px;">Company</h4>
        <ul style="list-style: none; padding: 0; margin: 0; line-height: 2.2; font-size: 14px;">
          <li><a href="#" style="color: #999; text-decoration: none;">About</a></li>
          <li><a href="#" style="color: #999; text-decoration: none;">Career</a></li>
          <li><a href="#" style="color: #999; text-decoration: none;">Factory</a></li>
        </ul>
      </div>

      <div style="flex: 1; min-width: 150px;">
        <h4 style="margin-bottom: 20px; font-size: 16px;">Get Help</h4>
        <ul style="list-style: none; padding: 0; margin: 0; line-height: 2.2; font-size: 14px;">
          <li><a href="#" style="color: #999; text-decoration: none;">Start A Return</a></li>
          <li><a href="#" style="color: #999; text-decoration: none;">Help Center</a></li>
          <li><a href="#" style="color: #999; text-decoration: none;">Return Policy</a></li>
          <li><a href="#" style="color: #999; text-decoration: none;">Privacy Policy</a></li>
        </ul>
      </div>

      <div style="flex: 2; min-width: 300px; border: 1px solid #333; padding: 20px;">
        <p style="color: #ccc; margin-bottom: 20px; font-size: 14px; text-align: center;">Subscribe to receive updates, access to exclusive deals, and more.</p>
        <div style="display: flex; gap: 10px;">
          <input type="email" placeholder="Your email address" style="flex: 1; padding: 12px; background: transparent; border: 1px solid #555; color: #fff; outline: none;">
          <button style="padding: 12px 20px; background: transparent; border: 1px solid #fff; color: #fff; cursor: pointer; text-transform: uppercase; font-size: 12px; letter-spacing: 1px;">Subscribe</button>
        </div>
      </div>

    </div>
  </footer>
</body>
</html>